# Required for HuggingFace gated models (Gemma, Llama).
HF_TOKEN=

# Optional. Only needed for:
#   - scripts/01_generate_concept_data.py  (GPT-5 generates concept JSONs)
#   - scripts/10_rejudge.py with --judge openai  (cross-judge robustness, paper §B.3)
OPENAI_API_KEY=

# Optional. Only needed for scripts/10_rejudge.py with --judge bedrock.
# Install the Bedrock extra to use this:  uv sync --extra bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
